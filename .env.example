VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Office geofence settings
VITE_OFFICE_LAT=25.5788
VITE_OFFICE_LNG=91.8933
VITE_OFFICE_RADIUS_METERS=100

# Optional: fallback admin login for local demo only.
# Production should use Firebase Auth admin account + custom admin claim.
VITE_DEMO_ADMIN_EMAIL=admin@geofence.com
VITE_DEMO_ADMIN_PASSWORD=admin123456
